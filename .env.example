# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM Providers Keys
GROQ_API_KEY=gsk_your_key
GEMINI_API_KEY=AIzaSy...

# Sourcing & Enrichment Keys
GOOGLE_CSE_API_KEY=your_google_cse_key
GOOGLE_CSE_ENGINE_ID=your_google_cse_cx_id
SERPAPI_API_KEY=your_serpapi_key
HUNTER_API_KEY=your_hunter_api_key

# Email Sending (SMTP / Gmail)
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Email Sending (Resend)
RESEND_API_KEY=re_your_key
RESEND_SENDER_EMAIL=applications@apply.yourdomain.com
SEND_DISABLED=false

# Monitoring & Controls
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
SYSTEM_PAUSED=false
AUTO_APPROVE=false
PORTFOLIO_URL=https://your-portfolio-site.com

# Candidate Personal Info overrides (for repository anonymization)
CANDIDATE_EMAIL=your_email@gmail.com
CANDIDATE_PHONE=+1 123 456 7890
CANDIDATE_CITY=City, Country
CANDIDATE_LOCATION=Street Address, City
